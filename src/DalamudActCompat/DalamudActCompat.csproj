<Project Sdk="Dalamud.NET.Sdk/14.0.1">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <AssemblyName>DalamudActCompat</AssemblyName>
    <RootNamespace>DalamudActCompat</RootNamespace>
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <Name>Dalamud ACT Compat</Name>
    <Author>raynording</Author>
    <Punchline>In-game ACT-compatible parsing platform foundation.</Punchline>
